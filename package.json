{
  "name": "nometer",
  "private": false,
  "version": "0.5.0",
  "description": "No credits, no limits, no uploads: local-first file conversion and PDF tools.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "native:sync-ffmpeg": "node scripts/sync-ffmpeg-sidecars.mjs",
    "native:sync-pandoc": "node scripts/sync-pandoc-sidecars.mjs",
    "native:sync-qpdf": "node scripts/sync-qpdf-sidecars.mjs",
    "native:sync-sidecars": "npm.cmd run native:sync-ffmpeg && npm.cmd run native:sync-pandoc && npm.cmd run native:sync-qpdf",
    "native:relocate-tauri-cache": "node scripts/relocate-tauri-cache.mjs",
    "native:doctor": "node scripts/native-doctor.mjs",
    "release:checksums": "node scripts/release-checksums.mjs",
    "release:provenance": "node scripts/release-provenance.mjs",
    "release:prepare": "node scripts/release-prepare.mjs",
    "release:notes": "node scripts/release-notes.mjs",
    "release:smoke": "node scripts/release-smoke.mjs",
    "release:review-check": "node scripts/release-review-check.mjs",
    "tauri": "node scripts/with-d-toolchain.mjs -- tauri",
    "desktop:dev": "node scripts/with-d-toolchain.mjs -- tauri dev",
    "desktop:build": "node scripts/with-d-toolchain.mjs -- tauri build && node scripts/relocate-tauri-cache.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
